# Google Sheets API - Service Account credentials
# Get these from your Google Cloud Console service account JSON key file
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The ID of your Google Sheet (from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit)
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Simple admin password to protect the dashboard
ADMIN_PIN=1234

# Your app's public URL (set after first Vercel deploy)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
