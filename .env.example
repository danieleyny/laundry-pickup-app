# Google Sheets API - Service Account credentials
# Get these from your Google Cloud Console service account JSON key file
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The ID of your Google Sheet (from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit)
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Simple admin password to protect the dashboard
ADMIN_PIN=1234

# Your app's public URL (set after first Vercel deploy)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Late-signup email alerts (optional) ──
# Gmail account + app password used to send the "Late Pickup Signup" alerts
GMAIL_USER=laundrydaynyc@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
ALERT_EMAIL=laundrydaynyc@gmail.com

# ── Driver photos (Vercel Blob) ──
# Create a Blob store in Vercel → Storage → Blob and connect it to this project;
# Vercel then sets this automatically in production. Copy it here for local dev.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# Separate PIN for drivers (photo upload only — keeps the admin PIN private).
# If unset, drivers must use the ADMIN_PIN.
DRIVER_PIN=5678

# How many days driver photos are kept before the daily cleanup deletes them.
# Minimum is 30 — the app enforces at least 30 days no matter what you set.
PHOTO_RETENTION_DAYS=30

# Secret protecting the daily cleanup endpoint. Set the same value in Vercel;
# Vercel Cron automatically sends it as a Bearer token.
CRON_SECRET=generate-a-long-random-string-here
